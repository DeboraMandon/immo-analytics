# immo-analytics — Variables d'environnement
# cp .env.example .env puis adapter les valeurs
# Ne JAMAIS committer .env sur Git

# ── Base de données ───────────────────────────────────────────
POSTGRES_PASSWORD=Immo2026
DATABASE_URL=postgresql://immo_user:Immo2026@postgres:5432/immo_dashboard

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW_DB_PASSWORD=airflow_secret
AIRFLOW_FERNET_KEY=                  # générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_SECRET_KEY=immo_analytics_secret
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_UID=50000

# ── INSEE API (optionnel) ─────────────────────────────────────
# Token gratuit sur : https://portail-api.insee.fr/
INSEE_API_TOKEN=

# ── DVF ───────────────────────────────────────────────────────
DVF_ANNEE=2025
